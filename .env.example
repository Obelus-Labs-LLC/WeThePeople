# WeThePeople — Environment Variables
# Copy to .env and fill in real values.

# --- Mobile App (Expo) ---
# API URL used by the mobile app at build time.
# Defaults to localhost if not set; production should point to the Hetzner server.
WTP_API_URL=http://localhost:8006

# --- External API keys (required for data ingestion) ---
CONGRESS_API_KEY=your_congress_gov_key
QUIVER_API_KEY=your_quiver_quantitative_key
ANTHROPIC_API_KEY=your_anthropic_key
OPENSANCTIONS_API_KEY=your_opensanctions_key
FEC_API_KEY=your_fec_key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
FRED_API_KEY=your_fred_key

# --- External API keys (optional) ---
OPENSTATES_API_KEY=your_openstates_key
API_KEY_GOOGLE_CIVIC=your_google_civic_key
API_KEY_INTERNET_ARCHIVE_S3_ACCESS=your_ia_s3_access
API_KEY_INTERNET_ARCHIVE_S3_SECRET=your_ia_s3_secret

# --- Database ---
# SQLite (default) or PostgreSQL (psycopg2-binary included in requirements.txt)
WTP_DB_URL=sqlite:///./wethepeople.db

# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Pilot cohort (dev) ---
PILOT_PERSON_IDS=alexandria_ocasio_cortez,bernie_sanders,chuck_schumer,elizabeth_warren,ron_wyden

# --- API Auth (Press Tier) ---
# Set WTP_REQUIRE_AUTH=1 in production to enforce API key gating.
# WTP_PRESS_API_KEY is the key that press clients must provide.
WTP_REQUIRE_AUTH=0
WTP_PRESS_API_KEY=
WTP_ENTERPRISE_API_KEY=

# --- Twitter/X Bot (@WTPForUs) ---
# Tier: Basic ($200/month) — 3,000 posts/month
# OAuth 1.0a credentials (get from X Developer Portal > Keys and Tokens)
TWITTER_CONSUMER_KEY=your_consumer_key
TWITTER_CONSUMER_SECRET=your_consumer_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
# Bearer token for read-only operations (search, user lookup)
TWITTER_BEARER_TOKEN=your_bearer_token

# --- Twitter Bot Configuration ---
# Kill switch: set to 1 to immediately halt ALL posting without redeploying
WTP_BOT_PAUSED=0
# Gate 5: set to 1 to only post human-approved stories (recommended)
WTP_BOT_STORIES_ONLY=1
# Auto-quote: set to 1 to allow direct posting of auto-quotes (not recommended)
# Default (0) saves auto-quotes as drafts for human review
WTP_AUTO_QUOTE_DIRECT=0

# --- Email (Story Review Digest) ---
SENDGRID_API_KEY=
WTP_REVIEW_EMAIL=wethepeopleforus@gmail.com

# --- Stripe (future) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
