# WeThePeople — Environment Variables
# Copy to .env and fill in real values.

# --- Mobile App (Expo) ---
# API URL used by the mobile app at build time.
# Defaults to localhost if not set; production should point to the GCP VM.
WTP_API_URL=http://localhost:8006

# --- External API keys (required for data ingestion) ---
CONGRESS_API_KEY=your_congress_gov_key
QUIVER_API_KEY=your_quiver_quantitative_key
ANTHROPIC_API_KEY=your_anthropic_key
OPENSANCTIONS_API_KEY=your_opensanctions_key
FEC_API_KEY=your_fec_key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
FRED_API_KEY=your_fred_key

# --- External API keys (optional) ---
OPENSTATES_API_KEY=your_openstates_key
API_KEY_GOOGLE_CIVIC=your_google_civic_key
API_KEY_INTERNET_ARCHIVE_S3_ACCESS=your_ia_s3_access
API_KEY_INTERNET_ARCHIVE_S3_SECRET=your_ia_s3_secret

# --- Database ---
# SQLite (default) or PostgreSQL (psycopg2-binary included in requirements.txt)
WTP_DB_URL=sqlite:///./wethepeople.db

# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Pilot cohort (dev) ---
PILOT_PERSON_IDS=alexandria_ocasio_cortez,bernie_sanders,chuck_schumer,elizabeth_warren,ron_wyden

# --- API Auth (Press Tier) ---
# Set WTP_REQUIRE_AUTH=1 in production to enforce API key gating.
# WTP_PRESS_API_KEY is the key that press clients must provide.
WTP_REQUIRE_AUTH=0
WTP_PRESS_API_KEY=

# --- Enterprise Tier (Claim Verification) ---
WTP_ENTERPRISE_API_KEY=

# --- Twitter/X Bot (@WTPForUs) ---
TWITTER_BEARER_TOKEN=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
