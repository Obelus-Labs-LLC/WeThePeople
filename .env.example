# WeThePeople Backend — Environment Variables
# Copy to .env and fill in real values.

# --- External API keys (required for data ingestion) ---
API_KEY_CONGRESS=your_congress_gov_key
API_KEY_OPENSTATES=your_openstates_key
API_KEY_INTERNET_ARCHIVE_S3_ACCESS=your_ia_s3_access
API_KEY_INTERNET_ARCHIVE_S3_SECRET=your_ia_s3_secret
API_KEY_ENIGMA=your_enigma_key
API_KEY_CENSUS=your_census_key
API_KEY_DATA_GOV=your_data_gov_key
API_KEY_GOOGLE_CIVIC=your_google_civic_key
ANTHROPIC_API_KEY=your_anthropic_key

# --- Database ---
WTP_DB_URL=sqlite:///./wethepeople.db

# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Pilot cohort (dev) ---
PILOT_PERSON_IDS=alexandria_ocasio_cortez,bernie_sanders,chuck_schumer,elizabeth_warren,ron_wyden

# --- API Auth (Press Tier) ---
# Set WTP_REQUIRE_AUTH=1 in production to enforce API key gating.
# WTP_PRESS_API_KEY is the key that press clients must provide.
WTP_REQUIRE_AUTH=0
WTP_PRESS_API_KEY=
