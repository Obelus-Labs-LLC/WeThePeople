# ── Markdown policy ────────────────────────────────────────────────
# Per the May 4 2026 cleanup: NO markdown files in this repo except
# project-level README.md files. All planning docs, prompts, audits,
# editorial standards, architecture notes, and bug logs stay LOCAL
# only. They live on the operator's machine (preserved at
# ../md-archive-local/ in the worktree). If a file is genuinely
# needed in the repo, force-add with `git add -f` and update this
# allowlist to be explicit.
*.md
!README.md
!**/README.md
# Specific READMEs that should ALSO stay local-only
frontend/README.md
frontend/src/api/README.md

# Other local-only contexts
.serena/

# Internal docs & archive (local only)
docs/
_archive/

# Seed/reference data (local only, too large or too volatile for git)
data/
!frontend/src/data/
!mobile/src/data/
audit/

# Logos (local only — not code)
frontend/public/logos/

# Build artifacts
frontend/tsconfig.tsbuildinfo

# Alembic generated readme
alembic/README
wallet_wtpdb/
prompts.env

# Planning scratch (local only — audit notes, story/rehab snapshots, design handoffs)
# Design handoffs contain superseded copy (fabricated Knight Foundation claim,
# fake @wethepeopleforus.com mailboxes) that must NEVER reach the public repo.
.planning/

# One-off rehab / audit scripts (kept locally for rerun reference, not shipped)
scripts/rehab_*.py
