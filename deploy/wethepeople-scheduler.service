# DEPLOYMENT: Before installing, substitute placeholders:
#   sed -i 's|%USER%|dshon|g; s|%HOME%|/home/dshon|g' wethepeople-scheduler.service
#   sudo cp wethepeople-scheduler.service /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now wethepeople-scheduler

[Unit]
Description=WeThePeople Sync Scheduler
After=network.target wethepeople.service
Wants=wethepeople.service

[Service]
Type=simple
User=%USER%
Group=%USER%
WorkingDirectory=%HOME%/wethepeople-backend
EnvironmentFile=%HOME%/wethepeople-backend/.env
ExecStart=%HOME%/wethepeople-backend/.venv/bin/python jobs/scheduler.py
Restart=on-failure
RestartSec=30
StandardOutput=journal
StandardError=journal

# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=%HOME%/wethepeople-backend

[Install]
WantedBy=multi-user.target
