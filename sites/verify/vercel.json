{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.wethepeopleforus.com/:path*"
    },
    {
      "source": "/claims/:path*",
      "destination": "https://api.wethepeopleforus.com/claims/:path*"
    },
    {
      "source": "/((?!api/|claims/).*)",
      "destination": "/index.html"
    }
  ]
}
